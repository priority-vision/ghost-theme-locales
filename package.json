{
	"name": "ghost-theme-locales",
	"version": "0.1.0",
	"description": "CLI tool to create locale json files in Ghost themes",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git@github.com:priority-vision/ghost-theme-locales.git"
	},
	"author": "Priority Vision <https://priority.vision>",
	"type": "module",
	"main": "./index.js",
	"types": "./index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		},
		"./extract-translatable-strings": {
			"types": "./lib/extract-translatable-strings.d.ts",
			"default": "./lib/extract-translatable-strings.js"
		}
	},
	"bin": {
		"gtl": "./cli.js",
		"ghost-theme-locales": "./cli.js"
	},
	"files": [
		"cli.js",
		"index.js",
		"index.d.ts",
		"lib"
	],
	"keywords": [
		"cli",
		"ghost",
		"theme",
		"locales",
		"json",
		"translation"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"glob": "^13.0.6",
		"meow": "^14.1.0",
		"ora": "^9.3.0"
	},
	"devDependencies": {
		"@types/node": "^24.5.2",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}
